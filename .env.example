# Copy this file to .env locally:
#   cp .env.example .env
# On Render: add each non-comment line under "Environment" in service settings.

# --- AI provider (Groq, free tier) ---
# 1. Sign up at https://console.groq.com (free, no credit card)
# 2. Create an API key at https://console.groq.com/keys
# 3. Paste it below.
GROQ_API_KEY=

# Optional: pick a different Groq model. See https://console.groq.com/docs/models
# Defaults to llama-3.1-8b-instant (fast, free tier).
GROQ_MODEL=llama-3.1-8b-instant

# Optional: swap providers later. Any OpenAI-compatible /v1 base URL works
# (OpenRouter: https://openrouter.ai/api/v1, Together: https://api.together.xyz/v1,
# OpenAI itself: https://api.openai.com/v1). Set the matching key in GROQ_API_KEY.
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Access control ---
# Users request access by submitting their email. The admin (you) approves
# them from /admin and a single-use, 1-hour code is emailed to them.

# Admin login (HTTP Basic Auth) for /admin
ADMIN_USER=admin
ADMIN_PASS=change-this-to-something-long-and-random

# SMTP for sending approval-code emails (Gmail recommended for free setup).
# To get an app password:
#   1. Turn on 2FA on your Google account
#   2. Visit https://myaccount.google.com/apppasswords
#   3. Create a 16-char app password for "Mail" and paste it below
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-char-app-password

# Address that receives new-access-request notifications. Defaults to SMTP_USER.
ADMIN_EMAIL=

# Public URL of this app, used in email links.
# Local:  http://localhost:3000
# Render: https://your-service.onrender.com
APP_URL=http://localhost:3000
APP_NAME=Docket

# --- General server settings ---
PORT=3000
MAX_UPLOAD_MB=25
# Path to the SQLite database file (created automatically if missing).
DB_PATH=
